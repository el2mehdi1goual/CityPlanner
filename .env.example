# AI Urban Design Planner - Configuration d'environnement

# Django
DEBUG=True
SECRET_KEY=your-secret-key-here

# Base de données MySQL
DB_ENGINE=django.db.backends.mysql
DB_NAME=ai_urban_design
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Configuration SMTP (pour les emails)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# AWS (optionnel pour S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=

# Sentry (optionnel pour logging)
# SENTRY_DSN=

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Gemini (image prompt generation)
# IMPORTANT: put your real key in your local `.env`, never commit it.
GEMINI_API_KEY=your-gemini-api-key-here

# Optional model overrides (safe defaults)
GEMINI_TEXT_MODEL=models/gemini-3-flash-preview